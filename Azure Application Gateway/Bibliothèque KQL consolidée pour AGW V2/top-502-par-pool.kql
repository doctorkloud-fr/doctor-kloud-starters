// Top 502/504 par Backend pool sur 24h
// Usage : standup Cloud Ops du matin
// Auteur : Doctor Kloud — v1.0.0
AzureDiagnostics
| where ResourceProvider == "MICROSOFT.NETWORK"
| where Category == "ApplicationGatewayAccessLog"
| where TimeGenerated > ago(24h)
| where httpStatus_d in (502, 504)
| summarize
    Count502 = countif(httpStatus_d == 502),
    Count504 = countif(httpStatus_d == 504),
    Total = count()
    by backendPoolName_s
| order by Total desc
