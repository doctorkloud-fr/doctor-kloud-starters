// Top Rules WAF bloquantes sur 24h
// Usage : investigation faux positifs
// Auteur : Doctor Kloud — v1.0.0
AzureDiagnostics
| where ResourceProvider == "MICROSOFT.NETWORK"
| where Category == "ApplicationGatewayFirewallLog"
| where TimeGenerated > ago(24h)
| where action_s == "Blocked"
| summarize
    nb_blocked = count(),
    nb_ips = dcount(clientIp_s),
    top_uris = make_set(requestUri_s, 3)
    by ruleId_s, ruleSetType_s
| order by nb_blocked desc
| take 20
